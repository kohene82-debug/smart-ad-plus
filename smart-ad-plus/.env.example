# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/smart_ad_plus

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── AUTH ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_string_in_production
JWT_EXPIRES_IN=7d
ADVERTISER_JWT_SECRET=change_this_advertiser_secret_too
ADMIN_JWT_SECRET=change_this_admin_secret_too

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── TWILIO (OTP) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# Set to "true" to use mock OTP in dev (returns dev_otp in response)
OTP_MOCK_MODE=true

# ─── REVENUE SPLIT ────────────────────────────────────────────────────────────
USER_REVENUE_SHARE=0.60
PLATFORM_REVENUE_SHARE=0.40

# ─── CLOUD STORAGE ────────────────────────────────────────────────────────────
# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=smart-ad-plus-media

# Cloudinary (alternative)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── PAYMENT GATEWAYS ─────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Active gateway: paystack | stripe | flutterwave
PAYMENT_GATEWAY=paystack

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AD_REQUEST_RATE_LIMIT=10
OTP_RATE_LIMIT=5

# ─── FRAUD PREVENTION ────────────────────────────────────────────────────────
MIN_IMPRESSION_INTERVAL_SECONDS=30
MAX_IMPRESSIONS_PER_DAY=50

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── ADMIN ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@smartadplus.com
ADMIN_PASSWORD=Admin@123456
